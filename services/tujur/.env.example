ANTHROPIC_API_KEY=your-anthropic-api-key

# PoC: PMS-Integration ist ein DB-Ledger statt Mews. Mews-Tokens stehen für Phase 2 bereit.
PMS_BACKEND=db_ledger  # db_ledger | mews

DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Mews — public demo tokens. Inactive while PMS_BACKEND=db_ledger.
MEWS_CLIENT_TOKEN=E0D439EE522F44368DC78E1BFB03710C-D24FB11DBE31D4621C4817E028D9E1D
MEWS_ACCESS_TOKEN=C66EF7B239D24632943D115EDE9CB810-EA00F8FD8294692C940F6B5A8F9453D
MEWS_SERVICE_ID=your-mews-service-id
MEWS_DEMO=true

# Microsoft Graph — app identity (one set, shared across all hotels)
AZURE_CLIENT_ID=495ce279-7fa5-4d14-87d3-cb98a880a988
AZURE_CLIENT_SECRET=your-azure-client-secret

# Hotel-specific (single-hotel MVP — moves to a Hotel table when we onboard #2)
HOTEL_TENANT_ID=your-hotel-azure-tenant-id
HOTEL_MAILBOX=bookings@your-hotel.com

# Webhook callback for Graph change notifications. Must be HTTPS, publicly reachable.
GRAPH_WEBHOOK_URL=https://your-app.up.railway.app/webhook/outlook-notification
GRAPH_WEBHOOK_CLIENT_STATE=generate-a-random-secret-and-keep-it
